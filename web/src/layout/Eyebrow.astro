---
/**
 * Section eyebrow per redesign §7.4 — `\ LABEL` or `\ NN / LABEL`.
 *
 * Renders an orange backslash, an optional zero-padded ordinal, then the
 * mono uppercase label. Default color is `text-ink-500`; override via the
 * `class` prop for darker surfaces (e.g. `text-cobalt-100` in the footer).
 */
type Tag = 'p' | 'h2' | 'h3' | 'h4' | 'dt' | 'span' | 'figcaption'

type Props = {
  /** Section ordinal (1, 2, 3…). Rendered zero-padded to two digits. */
  index?: number
  label: string
  /** HTML element to render. Defaults to `<p>`. */
  as?: Tag
  class?: string
}

const { index, label, as: Tag = 'p', class: className } = Astro.props
const numStr = index !== undefined ? String(index).padStart(2, '0') : null
---

<Tag class:list={['text-ink-500 tracking-eyebrow font-mono text-xs uppercase', className]}>
  <span class="text-orange-600" aria-hidden="true">\</span>
  {
    numStr ? (
      <>
        <span class="ml-1">{numStr}</span>
        <span class="text-ink-300 mx-1.5" aria-hidden="true">
          /
        </span>
        <span>{label}</span>
      </>
    ) : (
      <span class="ml-1">{label}</span>
    )
  }
</Tag>
