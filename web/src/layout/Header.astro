---
import { defaultLocale } from '@/cms/locales'
import type { Page, SeoMetadata } from 'cms/src/payload-types'
import Link from '../components/Link.astro'
import { normalizePath } from '../utils/normalizePath'

type Props = {
  alternatePaths: SeoMetadata['alternatePaths']
}

const { alternatePaths } = Astro.props
const { locale, preview, labels, header } = Astro.locals.globalState

const currentPath = Astro.url.pathname

// NOTE: when the 404 page is rendered, the locale might be undefined; fall back to default locale
const homePagePath = normalizePath(`/${locale ?? defaultLocale}`, preview)

const isCurrentLink = (link: { page?: { value: string | Page } }) =>
  currentPath === normalizePath((link.page?.value as Page)?.path, preview)
---

<header
  id="header"
  data-collapsed="false"
  class="site-header ease-standard sticky top-0 z-40 w-full transition-[height,background-color,border-color] duration-200"
>
  <div class="max-w-page mx-auto flex h-full items-center justify-between px-5 md:px-8">
    <a href={homePagePath} class="brand-lockup flex items-center gap-2" aria-label="JHB Software">
      <svg
        class="brand-mark block shrink-0"
        width="32"
        height="32"
        viewBox="0 0 96 96"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <rect width="96" height="96" fill="var(--color-primary)"></rect>
        <text
          x="48"
          y="52"
          text-anchor="middle"
          dominant-baseline="central"
          font-family="var(--font-sans)"
          font-size="40"
          font-weight="800"
          letter-spacing="-1.5"
          fill="#ffffff">JHB</text
        >
      </svg>
      <span class="text-primary tracking-wordmark font-sans text-base font-bold" aria-hidden="true">
        Software
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      <ul class="flex list-none items-center gap-1">
        {
          header.links?.map(({ link }) => (
            <li class:list={[link.style === 'primary' && 'mx-3']}>
              {link.style === 'primary' ? (
                <Link {...link} uppercase={false} class="!px-4 !py-2" />
              ) : (
                <a
                  href={normalizePath((link.page?.value as Page)?.path, preview)}
                  data-active={isCurrentLink(link)}
                  class="nav-link text-neutral-muted hover:text-primary data-[active=true]:text-primary ease-standard relative inline-flex items-center px-3 py-2 font-sans text-sm font-medium transition-colors duration-150"
                >
                  {link.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>

      <div class="lang-switcher ml-4 flex items-center gap-1.5 font-mono text-xs uppercase">
        {
          alternatePaths.map(({ hreflang, path }, index) => (
            <>
              <a
                href={normalizePath(path, preview)}
                class:list={[
                  'ease-standard transition-colors duration-150',
                  hreflang === locale ? 'text-primary' : 'text-neutral-subtle hover:text-primary',
                ]}
              >
                {hreflang}
              </a>
              {index < alternatePaths.length - 1 && (
                <span class="text-tertiary" aria-hidden="true">
                  \
                </span>
              )}
            </>
          ))
        }
      </div>
    </nav>

    <button
      class="menu-toggle border-border-strong text-primary inline-flex h-10 w-10 items-center justify-center border md:hidden"
      id="menu-toggle"
      type="button"
      aria-controls="navbar-modal"
      aria-expanded="false"
      aria-label={labels.global['open-menu']}
      data-label-open={labels.global['open-menu']}
      data-label-close={labels.global['close-menu']}
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        aria-hidden="true"
      >
        <line x1="2" y1="5" x2="14" y2="5"></line>
        <line x1="2" y1="11" x2="14" y2="11"></line>
      </svg>
    </button>
  </div>
</header>

<section
  id="navbar-modal"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  class="bg-canvas fixed inset-0 z-50 hidden h-[100dvh] w-screen flex-col md:hidden"
>
  <div
    class="flex w-full shrink-0 items-center justify-between px-5 md:px-8"
    style="height: var(--header-h, 72px);"
  >
    <a href={homePagePath} class="flex items-center gap-2" aria-label="JHB Software">
      <svg
        width="32"
        height="32"
        viewBox="0 0 96 96"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <rect width="96" height="96" fill="var(--color-primary)"></rect>
        <text
          x="48"
          y="52"
          text-anchor="middle"
          dominant-baseline="central"
          font-family="var(--font-sans)"
          font-size="40"
          font-weight="800"
          letter-spacing="-1.5"
          fill="#ffffff">JHB</text
        >
      </svg>
      <span class="text-primary tracking-wordmark font-sans text-base font-bold"> Software </span>
    </a>
    <button
      class="border-border-strong text-primary inline-flex h-10 w-10 items-center justify-center border"
      id="menu-close"
      type="button"
      aria-label={labels.global['close-menu']}
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        aria-hidden="true"
      >
        <line x1="3" y1="3" x2="13" y2="13"></line>
        <line x1="13" y1="3" x2="3" y2="13"></line>
      </svg>
    </button>
  </div>

  <ul class="flex flex-col gap-1 px-5 pt-6 md:px-8">
    {
      header.links?.map(({ link }) => (
        <li>
          <a
            href={normalizePath((link.page?.value as Page)?.path, preview)}
            data-active={isCurrentLink(link)}
            class="text-neutral-muted hover:text-primary data-[active=true]:text-primary block py-2 font-sans text-xl font-medium tracking-tight"
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>

  <div
    class="border-border mx-5 mt-auto flex items-baseline gap-3 border-t pt-5 pb-[max(1.5rem,env(safe-area-inset-bottom))] font-mono text-base uppercase md:mx-8"
  >
    {
      alternatePaths.map(({ hreflang, path }, index) => (
        <>
          <a
            href={normalizePath(path, preview)}
            class:list={[
              'ease-standard inline-flex items-center py-2 transition-colors duration-150',
              hreflang === locale ? 'text-primary' : 'text-neutral-subtle',
            ]}
          >
            {hreflang}
          </a>
          {index < alternatePaths.length - 1 && (
            <span class="text-tertiary" aria-hidden="true">
              \
            </span>
          )}
        </>
      ))
    }
  </div>
</section>

<style>
  .site-header {
    height: 72px;
    background-color: transparent;
    border-bottom: 1px solid transparent;
  }

  /* Collapsed state — toggled by JS via data-collapsed. Wrapped in :global() so
     the linter doesn't flag the runtime-only attribute selectors as unused. */
  :global(.site-header[data-collapsed='true']) {
    height: 56px;
    background-color: var(--color-surface);
    border-bottom-color: var(--color-border);
  }

  /* Orange `\` indicator before nav links — visible when active or hovered */
  .nav-link::before {
    content: '\\';
    font-family: var(--font-mono);
    color: var(--color-tertiary);
    margin-right: 0.375rem;
    opacity: 0;
    transform: translateX(0.25rem);
    transition:
      opacity 120ms var(--ease-standard),
      transform 120ms var(--ease-standard);
  }

  .nav-link:hover::before,
  .nav-link[data-active='true']::before {
    opacity: 1;
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .nav-link::before {
      transition: none;
    }
  }
</style>

<script>
  type HeaderState = {
    sentinel: HTMLDivElement
    observer: IntersectionObserver
    onMenuToggle: (event: Event) => void
    onMenuClose: () => void
    onPageHide: () => void
  }

  let state: HeaderState | null = null

  let lockedScrollY = 0

  function lockScroll() {
    lockedScrollY = window.scrollY
    document.body.style.position = 'fixed'
    document.body.style.top = `-${lockedScrollY}px`
    document.body.style.left = '0'
    document.body.style.right = '0'
    document.body.style.width = '100%'
  }

  function unlockScroll() {
    document.body.style.position = ''
    document.body.style.top = ''
    document.body.style.left = ''
    document.body.style.right = ''
    document.body.style.width = ''
    window.scrollTo(0, lockedScrollY)
  }

  function teardown() {
    if (!state) return
    state.observer.disconnect()
    state.sentinel.remove()
    if (document.body.style.position === 'fixed') unlockScroll()
    document.getElementById('menu-toggle')?.removeEventListener('click', state.onMenuToggle)
    document.getElementById('menu-close')?.removeEventListener('click', state.onMenuClose)
    document.removeEventListener('astro:before-swap', state.onPageHide)
    state = null
  }

  function setupHeader() {
    const header = document.getElementById('header') as HTMLElement | null
    const toggle = document.getElementById('menu-toggle') as HTMLButtonElement | null
    const close = document.getElementById('menu-close') as HTMLButtonElement | null
    const modal = document.getElementById('navbar-modal') as HTMLElement | null
    if (!header || !toggle || !modal) return

    teardown()

    // Sentinel intercepts the 80px scroll threshold for header collapse
    const sentinel = document.createElement('div')
    sentinel.setAttribute('aria-hidden', 'true')
    sentinel.style.cssText =
      'position:absolute;top:0;left:0;height:80px;width:1px;pointer-events:none'
    header.parentElement?.insertBefore(sentinel, header)

    const observer = new IntersectionObserver(
      ([entry]) => {
        header.dataset.collapsed = (!entry.isIntersecting).toString()
      },
      { threshold: 0 },
    )
    observer.observe(sentinel)

    function openMenu() {
      // Match modal's top-bar height to the header's current height so the
      // close button lands exactly where the hamburger was — no shift.
      const headerHeight = header!.getBoundingClientRect().height
      document.documentElement.style.setProperty('--header-h', `${headerHeight}px`)
      lockScroll()
      modal!.classList.remove('hidden')
      modal!.classList.add('flex')
      modal!.setAttribute('aria-hidden', 'false')
      toggle!.setAttribute('aria-expanded', 'true')
      toggle!.setAttribute('aria-label', toggle!.dataset.labelClose ?? '')
    }

    function closeMenu() {
      modal!.classList.add('hidden')
      modal!.classList.remove('flex')
      modal!.setAttribute('aria-hidden', 'true')
      toggle!.setAttribute('aria-expanded', 'false')
      toggle!.setAttribute('aria-label', toggle!.dataset.labelOpen ?? '')
      unlockScroll()
    }

    const onMenuToggle = () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true'
      if (expanded) closeMenu()
      else openMenu()
    }
    const onMenuClose = () => closeMenu()
    const onPageHide = () => teardown()

    toggle.addEventListener('click', onMenuToggle)
    close?.addEventListener('click', onMenuClose)
    document.addEventListener('astro:before-swap', onPageHide, { once: true })

    state = { sentinel, observer, onMenuToggle, onMenuClose, onPageHide }
  }

  document.addEventListener('astro:page-load', setupHeader)
</script>
