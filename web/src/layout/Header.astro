---
import { defaultLocale } from '@/cms/locales'
import { websiteConfig } from '@/config'
import type { Page, SeoMetadata } from 'cms/src/payload-types'
import Link from '../components/Link.astro'
import { normalizePath } from '../utils/normalizePath'

type Props = {
  alternatePaths: SeoMetadata['alternatePaths']
}

const { alternatePaths } = Astro.props
const { locale, preview, labels, header } = Astro.locals.globalState

const currentPath = Astro.url.pathname

// NOTE: when the 404 page is rendered, the locale might be undefined; fall back to default locale
const homePagePath = normalizePath(`/${locale ?? defaultLocale}`, preview)

const isCurrentLink = (link: { page?: { value: string | Page } }) =>
  currentPath === normalizePath((link.page?.value as Page)?.path, preview)
---

<header
  id="header"
  data-collapsed="false"
  class="site-header ease-standard sticky top-0 z-40 w-full transition-[height,background-color,border-color] duration-200"
>
  <div class="max-w-page mx-auto flex h-full items-center justify-between px-5 md:px-8">
    <a href={homePagePath} class="brand-lockup flex items-center gap-3" aria-label="JHB Software">
      <img
        src={websiteConfig.icon}
        alt=""
        width={32}
        height={32}
        class="brand-mark block shrink-0"
      />
      <span
        class="wordmark text-cobalt-900 tracking-wordmark font-sans text-base font-medium"
        aria-hidden="true"
      >
        <span class="wordmark-core">JHB</span><span class="wordmark-suffix"
          ><span class="wordmark-suffix-inner">Software</span></span
        >
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      <ul class="flex list-none items-center gap-1">
        {
          header.links?.map(({ link }) => (
            <li class:list={[link.style === 'primary' && 'mx-3']}>
              {link.style === 'primary' ? (
                <Link {...link} uppercase={false} class="!px-4 !py-2" />
              ) : (
                <a
                  href={normalizePath((link.page?.value as Page)?.path, preview)}
                  data-active={isCurrentLink(link)}
                  class="nav-link text-ink-700 hover:text-cobalt-900 data-[active=true]:text-cobalt-900 ease-standard relative inline-flex items-center px-3 py-2 font-sans text-sm font-medium transition-colors duration-150"
                >
                  {link.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>

      <div class="lang-switcher ml-4 flex items-center gap-1.5 font-mono text-xs uppercase">
        {
          alternatePaths.map(({ hreflang, path }, index) => (
            <>
              <a
                href={normalizePath(path, preview)}
                class:list={[
                  'ease-standard transition-colors duration-150',
                  hreflang === locale ? 'text-cobalt-900' : 'text-ink-500 hover:text-cobalt-900',
                ]}
              >
                {hreflang}
              </a>
              {index < alternatePaths.length - 1 && (
                <span class="text-orange-600" aria-hidden="true">
                  \
                </span>
              )}
            </>
          ))
        }
      </div>
    </nav>

    <button
      class="menu-toggle border-hairline-strong text-cobalt-900 inline-flex h-10 w-10 items-center justify-center border md:hidden"
      id="menu-toggle"
      type="button"
      aria-controls="navbar-modal"
      aria-expanded="false"
      aria-label={labels.global['open-menu']}
      data-label-open={labels.global['open-menu']}
      data-label-close={labels.global['close-menu']}
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        aria-hidden="true"
      >
        <line x1="2" y1="5" x2="14" y2="5"></line>
        <line x1="2" y1="11" x2="14" y2="11"></line>
      </svg>
    </button>
  </div>
</header>

<section
  id="navbar-modal"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  class="bg-paper fixed inset-0 z-50 hidden h-screen w-screen flex-col px-5 py-6 md:hidden"
>
  <div class="flex items-center justify-between">
    <a href={homePagePath} class="flex items-center gap-3" aria-label="JHB Software">
      <img src={websiteConfig.icon} alt="" width={32} height={32} />
      <span class="text-cobalt-900 tracking-wordmark font-sans text-base font-medium">
        JHB Software
      </span>
    </a>
    <button
      class="border-hairline-strong text-cobalt-900 inline-flex h-10 w-10 items-center justify-center border"
      id="menu-close"
      type="button"
      aria-label={labels.global['close-menu']}
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        aria-hidden="true"
      >
        <line x1="3" y1="3" x2="13" y2="13"></line>
        <line x1="13" y1="3" x2="3" y2="13"></line>
      </svg>
    </button>
  </div>

  <ul class="mt-12 flex flex-col gap-2">
    {
      header.links?.map(({ link }) => (
        <li>
          <a
            href={normalizePath((link.page?.value as Page)?.path, preview)}
            data-active={isCurrentLink(link)}
            class="text-ink-700 hover:text-cobalt-900 data-[active=true]:text-cobalt-900 block py-2 font-sans text-2xl font-medium tracking-tight"
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>

  <div class="mt-auto flex items-center gap-1.5 font-mono text-sm uppercase">
    {
      alternatePaths.map(({ hreflang, path }, index) => (
        <>
          <a
            href={normalizePath(path, preview)}
            class:list={[hreflang === locale ? 'text-cobalt-900' : 'text-ink-500']}
          >
            {hreflang}
          </a>
          {index < alternatePaths.length - 1 && (
            <span class="text-orange-600" aria-hidden="true">
              \
            </span>
          )}
        </>
      ))
    }
  </div>
</section>

<style>
  .site-header {
    height: 72px;
    background-color: transparent;
    border-bottom: 1px solid transparent;
  }

  /* Collapsed state — toggled by JS via data-collapsed. Wrapped in :global() so
     the linter doesn't flag the runtime-only attribute selectors as unused. */
  :global(.site-header[data-collapsed='true']) {
    height: 56px;
    background-color: var(--color-paper-pure);
    border-bottom-color: var(--color-hairline);
  }

  /* Wordmark: “JHB” stays; “ Software” clips away on scroll with a smooth lockup */
  .wordmark {
    --wordmark-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --wordmark-duration: 400ms;
    display: inline-flex;
    align-items: baseline;
    flex-wrap: nowrap;
    white-space: nowrap;
    column-gap: 0.35em;
  }

  .wordmark-suffix {
    display: inline-block;
    overflow: hidden;
    vertical-align: baseline;
    max-width: 7rem;
    opacity: 1;
    transition:
      max-width var(--wordmark-duration) var(--wordmark-ease),
      opacity 260ms var(--wordmark-ease);
  }

  .wordmark-suffix-inner {
    display: inline-block;
    transition: transform var(--wordmark-duration) var(--wordmark-ease);
  }

  :global(.site-header[data-collapsed='true']) .wordmark-suffix {
    max-width: 0;
    opacity: 0;
  }

  :global(.site-header[data-collapsed='true']) .wordmark-suffix-inner {
    transform: translate3d(-0.35rem, 0, 0);
  }

  /* Wordmark always hidden on mobile; mark + hamburger only */
  @media (max-width: 767px) {
    .wordmark {
      display: none;
    }
  }

  /* Orange `\` indicator before nav links — visible when active or hovered */
  .nav-link::before {
    content: '\\';
    font-family: var(--font-mono);
    color: var(--color-orange-600);
    margin-right: 0.375rem;
    opacity: 0;
    transform: translateX(0.25rem);
    transition:
      opacity 120ms var(--ease-standard),
      transform 120ms var(--ease-standard);
  }

  .nav-link:hover::before,
  .nav-link[data-active='true']::before {
    opacity: 1;
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .wordmark-suffix,
    .wordmark-suffix-inner,
    .nav-link::before {
      transition: none;
    }

    :global(.site-header[data-collapsed='true']) .wordmark-suffix-inner {
      transform: none;
    }
  }
</style>

<script>
  type HeaderState = {
    sentinel: HTMLDivElement
    observer: IntersectionObserver
    onMenuToggle: (event: Event) => void
    onMenuClose: () => void
    onPageHide: () => void
  }

  let state: HeaderState | null = null

  function teardown() {
    if (!state) return
    state.observer.disconnect()
    state.sentinel.remove()
    document.body.style.overflow = ''
    document.getElementById('menu-toggle')?.removeEventListener('click', state.onMenuToggle)
    document.getElementById('menu-close')?.removeEventListener('click', state.onMenuClose)
    document.removeEventListener('astro:before-swap', state.onPageHide)
    state = null
  }

  function setupHeader() {
    const header = document.getElementById('header') as HTMLElement | null
    const toggle = document.getElementById('menu-toggle') as HTMLButtonElement | null
    const close = document.getElementById('menu-close') as HTMLButtonElement | null
    const modal = document.getElementById('navbar-modal') as HTMLElement | null
    if (!header || !toggle || !modal) return

    teardown()

    // Sentinel intercepts the 80px scroll threshold for header collapse
    const sentinel = document.createElement('div')
    sentinel.setAttribute('aria-hidden', 'true')
    sentinel.style.cssText =
      'position:absolute;top:0;left:0;height:80px;width:1px;pointer-events:none'
    header.parentElement?.insertBefore(sentinel, header)

    const observer = new IntersectionObserver(
      ([entry]) => {
        header.dataset.collapsed = (!entry.isIntersecting).toString()
      },
      { threshold: 0 },
    )
    observer.observe(sentinel)

    function openMenu() {
      modal!.classList.remove('hidden')
      modal!.classList.add('flex')
      modal!.setAttribute('aria-hidden', 'false')
      toggle!.setAttribute('aria-expanded', 'true')
      toggle!.setAttribute('aria-label', toggle!.dataset.labelClose ?? '')
      document.body.style.overflow = 'hidden'
    }

    function closeMenu() {
      modal!.classList.add('hidden')
      modal!.classList.remove('flex')
      modal!.setAttribute('aria-hidden', 'true')
      toggle!.setAttribute('aria-expanded', 'false')
      toggle!.setAttribute('aria-label', toggle!.dataset.labelOpen ?? '')
      document.body.style.overflow = ''
    }

    const onMenuToggle = () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true'
      if (expanded) closeMenu()
      else openMenu()
    }
    const onMenuClose = () => closeMenu()
    const onPageHide = () => teardown()

    toggle.addEventListener('click', onMenuToggle)
    close?.addEventListener('click', onMenuClose)
    document.addEventListener('astro:before-swap', onPageHide, { once: true })

    state = { sentinel, observer, onMenuToggle, onMenuClose, onPageHide }
  }

  document.addEventListener('astro:page-load', setupHeader)
</script>
