---
import ArticleTagsList from '@/components/ArticleTagsList.astro'
import RichTextBlock from '@/components/blocks/RichTextBlock/RichTextBlock.astro'
import BreadcrumbsBlock from '@/components/Breadcrumbs.astro'
import Img from '@/components/Img.astro'
import TableOfContents from '@/components/TableOfContents.astro'
import Eyebrow from '@/layout/Eyebrow.astro'
import SectionShell from '@/layout/SectionShell.astro'
import { articleSchema } from '@/schema/article'
import { extractHeadings } from '@/utils/extractHeadings'
import { normalizePath } from '@/utils/normalizePath'
import type { LexicalNode } from '@jhb.software/astro-payload-richtext-lexical'
import { Schema } from 'astro-seo-schema'
import type { Article, Author, Breadcrumbs } from 'cms/src/payload-types'

type Props = {
  article: Article
  breadcrumbs: Breadcrumbs
}

const { article, breadcrumbs } = Astro.props
const { locale, preview, labels } = Astro.locals.globalState

const headings = extractHeadings(article.content.root.children as unknown as LexicalNode[])

const schema = articleSchema(article, locale)

const authors = (article.authors as Author[]) ?? []

const dateLabel = new Date(article.createdAt).toLocaleDateString(locale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const updatedLabel = new Date(article.updatedAt).toLocaleDateString(locale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

// TODO(cms-content): expose `published-at` and `tags` labels on the Articles
// collection (or a `Labels.articles` group) so editors can localise. Hardcoded
// here per redesign §12.11. Affects: every article detail page.
const publishedAtLabel = locale === 'en' ? 'Published' : 'Veröffentlicht am'
const tagsLabel = locale === 'en' ? 'Tags' : 'Themen'
---

<SectionShell class="pt-8 pb-24 md:pt-12">
  {breadcrumbs && <BreadcrumbsBlock crumbs={breadcrumbs} />}

  <header
    class="mt-3 grid grid-cols-1 gap-10 md:grid-cols-[minmax(0,1fr)_minmax(0,320px)] md:items-start md:gap-12"
  >
    <div class="space-y-5">
      <h1
        class="text-cobalt-900 font-sans text-3xl font-semibold tracking-tight text-balance md:text-4xl"
      >
        {article.title}
      </h1>

      {
        article.excerpt && (
          <p class="text-ink-700 font-sans text-base leading-[1.55] text-balance md:text-lg">
            {article.excerpt}
          </p>
        )
      }
    </div>

    {
      typeof article.image === 'object' && (
        <div class="border-hairline-strong overflow-hidden border md:mt-1">
          <Img
            image={article.image}
            size="md"
            class="block aspect-[4/3] h-full w-full object-cover"
            fetchpriority="high"
          />
        </div>
      )
    }
  </header>

  <div
    class="border-hairline mt-12 flex flex-wrap items-center gap-x-10 gap-y-5 border-t border-b py-5"
  >
    {
      authors.length > 0 && (
        <div class="flex items-center gap-3">
          <div class="flex flex-shrink-0 -space-x-2">
            {authors.map(
              (author) =>
                typeof author.photo === 'object' && (
                  <Img
                    image={author.photo}
                    size="sm"
                    class="border-paper-pure aspect-square !h-9 !w-9 rounded-full border-2 object-cover"
                  />
                ),
            )}
          </div>
          <div class="flex flex-col gap-0.5">
            <Eyebrow label={labels.articles['written-by']} />
            <p class="text-ink-950 font-sans text-sm">
              {authors.map((author, index) => (
                <>
                  {index > 0 && (index === authors.length - 1 ? ' & ' : ', ')}
                  <a
                    class="ease-standard decoration-hairline-strong inline-block font-medium text-nowrap underline underline-offset-4 transition-colors duration-150 hover:text-orange-600 hover:decoration-orange-600"
                    href={normalizePath(author.path, preview)}
                  >
                    {author.name}
                  </a>
                </>
              ))}
            </p>
          </div>
        </div>
      )
    }

    <div class="flex flex-col gap-0.5">
      <Eyebrow label={publishedAtLabel} />
      <p class="text-ink-950 font-sans text-sm">{dateLabel}</p>
    </div>

    <div class="flex flex-col gap-0.5">
      <Eyebrow label={labels.articles['last-updated-at']} />
      <p class="text-ink-950 font-sans text-sm">{updatedLabel}</p>
    </div>

    {
      article.tags && article.tags.length > 0 && (
        <div class="ml-auto flex flex-col gap-1.5">
          <Eyebrow label={tagsLabel} />
          <ArticleTagsList tags={article.tags} />
        </div>
      )
    }
  </div>

  {
    headings.length > 0 && (
      <div class="mt-10 xl:hidden">
        <TableOfContents headings={headings} />
      </div>
    )
  }

  <div class="prose-redesign relative mt-12 flex gap-12">
    <div class="min-w-0 flex-1">
      <RichTextBlock text={article.content} />
    </div>

    {
      headings.length > 0 && (
        <aside class="hidden w-64 flex-shrink-0 xl:block">
          <TableOfContents headings={headings} />
        </aside>
      )
    }
  </div>
</SectionShell>

<Schema item={schema} />
