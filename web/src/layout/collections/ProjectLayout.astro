---
import RichTextBlock from '@/components/blocks/RichTextBlock/RichTextBlock.astro'
import TestimonialsBlock from '@/components/blocks/TestimonialsBlock.astro'
import BreadcrumbsBlock from '@/components/Breadcrumbs.astro'
import Img from '@/components/Img.astro'
import ProjectDate from '@/components/ProjectDate.astro'
import ProjectTagsList from '@/components/ProjectTagsList.astro'
import SectionShell from '@/layout/SectionShell.astro'
import { projectSchema } from '@/schema/project'
import { Schema } from 'astro-seo-schema'
import type { Breadcrumbs, Project } from 'cms/src/payload-types'

type Props = {
  project: Project
  breadcrumbs: Breadcrumbs
}

const { project: pageData, breadcrumbs } = Astro.props
const { locale } = Astro.locals.globalState

const schema = projectSchema(pageData)

const testimonials =
  pageData.testimonials?.docs?.filter((testimonial) => typeof testimonial === 'object') || []

// TODO(cms-content): expose testimonials + metadata-strip labels on the
// Projects collection (or a global `Labels.projects` group) so editors can
// localise. Hardcoded here per redesign §12.11 because no CMS surface exists.
// Affects: every project detail page.
const testimonialsEyebrow = locale === 'en' ? 'VOICES' : 'STIMMEN'
const testimonialsHeading =
  locale === 'en' ? 'What clients say about this project' : 'Was Kunden zu diesem Projekt sagen'
const periodLabel = locale === 'en' ? 'Period' : 'Zeitraum'
const tagsLabel = locale === 'en' ? 'Tags' : 'Themen'
---

<SectionShell class="pt-8 pb-24 md:pt-12">
  {breadcrumbs && <BreadcrumbsBlock crumbs={breadcrumbs} />}

  <header class="mt-8 max-w-3xl space-y-5">
    <h1
      class="text-cobalt-900 font-sans text-4xl font-semibold tracking-tight text-balance md:text-5xl"
    >
      {pageData.title}
    </h1>

    {
      pageData.excerpt && (
        <p class="text-ink-700 max-w-2xl font-sans text-lg leading-[1.55] text-balance">
          {pageData.excerpt}
        </p>
      )
    }
  </header>

  {
    typeof pageData.image === 'object' && (
      <div class="border-hairline-strong mt-12 overflow-hidden border">
        <Img
          image={pageData.image}
          size="xl"
          class="block aspect-[16/9] h-full w-full object-cover"
          fetchpriority="high"
        />
      </div>
    )
  }

  <div
    class="border-hairline mt-12 flex flex-wrap items-center gap-x-10 gap-y-5 border-t border-b py-5"
  >
    <div class="flex flex-col gap-0.5">
      <p class="text-ink-500 tracking-eyebrow font-mono text-xs uppercase">
        <span class="text-orange-600" aria-hidden="true">\</span>
        <span class="ml-1.5">{periodLabel}</span>
      </p>
      <ProjectDate
        startDate={pageData.startDate}
        endDate={pageData.endDate}
        class="!text-ink-950 !font-sans !text-sm"
      />
    </div>

    {
      pageData.tags && pageData.tags.length > 0 && (
        <div class="ml-auto flex flex-col gap-1.5">
          <p class="text-ink-500 tracking-eyebrow font-mono text-xs uppercase">
            <span class="text-orange-600" aria-hidden="true">
              \
            </span>
            <span class="ml-1.5">{tagsLabel}</span>
          </p>
          <ProjectTagsList tags={pageData.tags} />
        </div>
      )
    }
  </div>

  <div class="prose-redesign mt-16 max-w-3xl">
    <RichTextBlock text={pageData.body} />
  </div>

  {
    testimonials.length > 0 && (
      <section class="mt-24 space-y-8">
        <header class="space-y-3">
          <p class="text-ink-500 tracking-eyebrow font-mono text-xs uppercase">
            <span class="text-orange-600" aria-hidden="true">
              \
            </span>
            <span class="ml-1.5">{testimonialsEyebrow}</span>
          </p>
          <h2 class="text-cobalt-900 font-sans text-2xl font-semibold tracking-tight md:text-3xl">
            {testimonialsHeading}
          </h2>
        </header>
        <TestimonialsBlock blockType="testimonials" testimonials={testimonials} />
      </section>
    )
  }
</SectionShell>

<Schema item={schema} />
