---
import type { Breadcrumbs, HeroSection } from 'cms/src/payload-types'
import BreadcrumbsBlock from '../components/Breadcrumbs.astro'
import Link from '../components/Link.astro'
import CornerMark from './CornerMark.astro'
import Heading from './Heading.astro'

export type Props = HeroSection & { breadcrumbs: Breadcrumbs }

const { title, subtitle, links, breadcrumbs } = Astro.props
---

<section class="max-w-page mx-auto px-5 pt-8 md:px-8 md:pt-12">
  <div class="hero-block border-hairline-strong relative border bg-white">
    <CornerMark position="top-left" />
    <CornerMark position="top-right" />
    <CornerMark position="bottom-left" />
    <CornerMark position="bottom-right" />

    <div
      class="relative z-10 flex flex-col items-center gap-6 px-5 py-24 text-center md:px-8 md:py-32"
    >
      {breadcrumbs && <BreadcrumbsBlock crumbs={breadcrumbs} />}
      <Heading as="h1" size="hero" class="max-w-3xl text-balance">
        {title}
      </Heading>
      <p class="text-ink-700 max-w-2xl font-sans text-lg leading-[1.55] text-balance">
        {subtitle}
      </p>
      <div class="mt-2 flex flex-wrap items-center justify-center gap-3">
        {links?.map(({ link }) => <Link {...link} />)}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-block::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--color-hairline-strong) 1px, transparent 1px),
      linear-gradient(to bottom, var(--color-hairline-strong) 1px, transparent 1px);
    background-size: 56px 56px;
    opacity: 0.55;
    pointer-events: none;
    -webkit-mask-image: radial-gradient(
      ellipse 70% 65% at 50% 55%,
      transparent 0%,
      transparent 35%,
      rgba(0, 0, 0, 0.6) 70%,
      rgba(0, 0, 0, 1) 100%
    );
    mask-image: radial-gradient(
      ellipse 70% 65% at 50% 55%,
      transparent 0%,
      transparent 35%,
      rgba(0, 0, 0, 0.6) 70%,
      rgba(0, 0, 0, 1) 100%
    );
  }
</style>
