---
import { defaultLocale } from '@/cms/locales'
import { websiteConfig } from '@/config'
import type { Page } from 'cms/src/payload-types'
import Icon from '../components/icons/Icon.astro'
import { normalizePath } from '../utils/normalizePath'
import CornerMark from './CornerMark.astro'
import Eyebrow from './Eyebrow.astro'

const { locale, preview, footer, header } = Astro.locals.globalState

const homePagePath = normalizePath(`/${locale ?? defaultLocale}`, preview)

const socialAccessibleNames: Record<string, string> = {
  github: 'GitHub',
  linkedin: 'LinkedIn',
  whatsapp: 'WhatsApp',
  instagram: 'Instagram',
  facebook: 'Facebook',
  youtube: 'YouTube',
  x: 'X',
}

type SocialIcon = 'github' | 'linkedin' | 'whatsapp' | 'instagram' | 'facebook' | 'youtube' | 'x'

// Top-level site pages — pulled from the header so editors curate one nav.
// The primary CTA (Kontakt button) is excluded; it lives in its own column.
const sitePages = header.links?.filter(({ link }) => link.style !== 'primary') ?? []
---

<footer class="bg-cobalt-900 relative mt-32 overflow-hidden text-white">
  <div class="absolute inset-x-0 top-0 h-px bg-orange-600" aria-hidden="true"></div>

  <CornerMark position="top-left" />
  <CornerMark position="top-right" />

  <div
    class="watermark-stack pointer-events-none absolute inset-x-0 bottom-0 text-center font-sans font-bold tracking-tight select-none"
    aria-hidden="true"
  >
    <div class="watermark watermark-base">JHB</div>
    <div class="watermark watermark-glow">JHB</div>
  </div>

  <div class="max-w-page relative mx-auto px-5 pt-12 pb-6 md:px-8">
    <div class="grid grid-cols-2 gap-12 md:grid-cols-3 md:gap-8">
      <div>
        <Eyebrow as="h2" label="Site" class="!text-cobalt-100" />
        <ul class="mt-4 flex flex-col gap-3">
          {
            sitePages.map(({ link }) => (
              <li>
                <a
                  href={normalizePath((link.page?.value as Page)?.path, preview)}
                  class="ease-standard text-sm font-medium transition-colors duration-150 hover:text-orange-600"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <Eyebrow as="h2" label="Social" class="!text-cobalt-100" />
        <ul class="mt-4 flex flex-wrap gap-2">
          {
            footer.socialLinks?.map(({ url, icon }) => (
              <li>
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={socialAccessibleNames[icon] ?? icon}
                  class="bg-cobalt-900/20 text-cobalt-100 ease-standard inline-flex h-10 w-10 items-center justify-center border border-white/20 backdrop-blur-md transition-colors duration-150 hover:border-orange-600 hover:text-orange-600"
                >
                  <Icon name={icon as SocialIcon} class="h-4 w-4" />
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="col-span-2 md:col-span-1">
        <Eyebrow as="h2" label="Kontakt" class="!text-cobalt-100" />
        <a
          href={`mailto:${websiteConfig.email}`}
          class="bg-cobalt-900/20 ease-standard group mt-4 flex items-center justify-between gap-4 border border-white/20 p-4 backdrop-blur-md transition-colors duration-150 hover:border-orange-600"
        >
          <span class="flex flex-col gap-1.5">
            <span class="text-cobalt-100/70 tracking-eyebrow font-mono text-[0.6875rem] uppercase">
              Schreib uns
            </span>
            <span class="font-mono text-sm break-all text-white group-hover:text-orange-600">
              {websiteConfig.email}
            </span>
          </span>
          <Icon
            name="arrow-right"
            class="ease-standard text-cobalt-100 h-5 w-5 shrink-0 transition group-hover:translate-x-0.5 group-hover:text-orange-600 motion-safe:duration-150"
          />
        </a>
      </div>
    </div>

    <div
      class="border-cobalt-800 relative mt-12 flex flex-col gap-4 border-t pt-6 md:flex-row md:items-center md:justify-between"
    >
      <a
        href={homePagePath}
        class="ease-standard text-cobalt-100 inline-flex items-center gap-3 text-xs transition-colors duration-150 hover:text-orange-600"
        aria-label="JHB Software"
      >
        <img src={websiteConfig.icon} alt="" width={20} height={20} />
        <span class="tracking-eyebrow font-mono uppercase">
          © {new Date().getFullYear()} JHB Software
        </span>
      </a>

      {
        footer.links && footer.links.length > 0 && (
          <ul class="text-cobalt-100/60 flex flex-wrap items-center gap-x-1.5 gap-y-2 font-mono text-xs">
            {footer.links.map(({ link }, index) => (
              <>
                {index > 0 && (
                  <li class="text-cobalt-800" aria-hidden="true">
                    \
                  </li>
                )}
                <li>
                  <a
                    href={normalizePath((link.page?.value as Page)?.path, preview)}
                    class="ease-standard transition-colors duration-150 hover:text-orange-600"
                  >
                    {link.label}
                  </a>
                </li>
              </>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</footer>

<style>
  /* Decorative brand watermark — fluid display type sized to the footer
     width, deliberately outside the §4.2 body type scale. The bottom half
     is hidden behind the footer edge via translateY.

     Two layers: a faint base, plus a brighter "glow" copy revealed by a
     radial mask that follows the cursor (--mx, --my). With no pointer or
     reduced motion, only the base shows. */
  .watermark-stack {
    --mx: 50%;
    --my: 50%;
  }
  .watermark {
    font-size: clamp(10rem, 34vw, 30rem);
    line-height: 0.85;
    color: var(--color-cobalt-800);
    transform: translateY(35%);
  }
  .watermark-glow {
    position: absolute;
    inset: 0;
    color: var(--color-cobalt-100);
    opacity: 0.18;
    -webkit-mask-image: radial-gradient(
      circle 320px at var(--mx) var(--my),
      black 0%,
      transparent 100%
    );
    mask-image: radial-gradient(circle 320px at var(--mx) var(--my), black 0%, transparent 100%);
  }
  .watermark-base {
    opacity: 0.45;
  }

  @media (prefers-reduced-motion: reduce) {
    .watermark-glow {
      display: none;
    }
  }
</style>

<script>
  function setupWatermark() {
    const stack = document.querySelector('.watermark-stack') as HTMLElement | null
    if (!stack) return
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    let raf = 0
    let pendingX = 0
    let pendingY = 0

    const onMove = (event: PointerEvent) => {
      const rect = stack.getBoundingClientRect()
      pendingX = event.clientX - rect.left
      pendingY = event.clientY - rect.top
      if (raf) return
      raf = requestAnimationFrame(() => {
        stack.style.setProperty('--mx', `${pendingX}px`)
        stack.style.setProperty('--my', `${pendingY}px`)
        raf = 0
      })
    }

    window.addEventListener('pointermove', onMove)

    document.addEventListener(
      'astro:before-swap',
      () => {
        window.removeEventListener('pointermove', onMove)
        if (raf) cancelAnimationFrame(raf)
      },
      { once: true },
    )
  }

  document.addEventListener('astro:page-load', setupWatermark)
</script>
