---
import type { Link, Page } from 'cms/src/payload-types'
import { normalizePath } from '../utils/normalizePath'
import Icon from './icons/Icon.astro'

type CmsLinkProps = Link & { class?: string; uppercase?: boolean }
type RawLinkProps = {
  path: string
  style: Link['style']
  class?: string
  icon?: Link['icon']
  normalizePath?: boolean
}
type Props = CmsLinkProps | RawLinkProps

/**
 * Per redesign §8.1 the system has two button variants (primary, ghost) and
 * one in-prose link style (§8.2). The CMS still exposes five legacy `style`
 * values; map them to the redesign variants here so authors don't see breakage.
 */
export function buttonStyles(style: Link['style']) {
  switch (style) {
    // Primary — filled cobalt button (the page's main conversion CTA)
    case 'primary':
      return 'inline-flex items-center gap-2 bg-cobalt-900 text-white hover:bg-cobalt-800 rounded-none px-5 py-3 font-sans text-sm font-medium ease-standard transition-colors duration-150 no-underline'

    // Ghost — transparent button with hairline border
    case 'light':
    case 'light-primary':
      return 'inline-flex items-center gap-2 border border-hairline-strong text-ink-950 hover:text-orange-600 rounded-none px-5 py-3 font-sans text-sm font-medium ease-standard transition-colors duration-150 no-underline'

    // In-prose link — underlined, hover turns orange
    case 'text':
    case 'text-primary':
    default:
      return 'inline-flex items-center gap-1.5 text-ink-950 hover:text-orange-600 ease-standard underline decoration-hairline-strong hover:decoration-orange-600 underline-offset-4 transition-colors duration-150'
  }
}

const rawPath =
  'path' in Astro.props
    ? Astro.props.path
    : 'page' in Astro.props
      ? (Astro.props.page?.value as Page)?.path
      : undefined

if (!rawPath) {
  throw new Error('A path is required to build a link. Got: ' + JSON.stringify(Astro.props))
}

const { preview } = Astro.locals.globalState
const normalizePathValue = 'normalizePath' in Astro.props ? Astro.props.normalizePath : true
const href = normalizePathValue ? normalizePath(rawPath, preview) : rawPath

const isPrimary = Astro.props.style === 'primary'
---

<a
  href={href}
  class:list={[
    buttonStyles(Astro.props.style),
    'uppercase' in Astro.props && Astro.props.uppercase && 'uppercase',
    Astro.props.class,
  ]}
>
  {'label' in Astro.props ? Astro.props.label : <slot />}
  {'icon' in Astro.props && Astro.props.icon && <Icon name={Astro.props.icon} />}
  {
    isPrimary && (
      <span class="font-mono text-xs opacity-70" aria-hidden="true">
        &rarr;
      </span>
    )
  }
</a>
