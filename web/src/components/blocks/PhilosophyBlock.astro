---
import type { PhilosophyBlock } from 'cms/src/payload-types'
import FrameCell from '../../layout/FrameCell.astro'
import SectionFrame from '../../layout/SectionFrame.astro'
import RichTextBlock from './RichTextBlock/RichTextBlock.astro'

export type Props = PhilosophyBlock

const { title, text, items } = Astro.props
---

<div class="space-y-10">
  {
    (title || text) && (
      <header class="max-w-2xl space-y-4">
        {title && (
          <h3 class="text-cobalt-900 font-sans text-2xl font-semibold tracking-tight">{title}</h3>
        )}
        {text && (
          <div class="text-ink-700 prose-redesign">
            <RichTextBlock text={text} />
          </div>
        )}
      </header>
    )
  }

  <SectionFrame class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4" corners={false}>
    {
      items.map((item, idx) => (
        <FrameCell
          class:list={[
            'p-6',
            idx > 0 && 'border-t border-t-[var(--color-hairline-strong)]',
            idx > 0 && 'sm:border-t-0',
            idx % 2 === 1 && 'sm:border-l sm:border-l-[var(--color-hairline-strong)]',
            idx >= 2 && 'sm:border-t sm:border-t-[var(--color-hairline-strong)]',
            idx % 4 !== 0 && 'lg:border-l lg:border-l-[var(--color-hairline-strong)]',
            'lg:border-t-0',
          ]}
        >
          <div class="flex h-8 w-8 items-center justify-center" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <rect
                x="1"
                y="1"
                width="18"
                height="18"
                stroke="var(--color-cobalt-900)"
                stroke-width="1.5"
              />
              <circle cx="10" cy="10" r="2.5" fill="var(--color-orange-600)" />
            </svg>
          </div>
          <h4 class="text-cobalt-900 mt-4 font-sans text-base font-semibold">{item.title}</h4>
          <p class="text-ink-700 mt-2 font-sans text-sm leading-[1.55]">{item.text}</p>
        </FrameCell>
      ))
    }
  </SectionFrame>
</div>
