---
/**
 * Inner card for `ServicesBlock` — schematic visual, eyebrow, heading,
 * description, arrow. Wrapped by `<FrameCell>` which controls the cell's
 * borders within the bento or 3-up grid.
 */
import type { Page, ServicesBlock } from 'cms/src/payload-types'
import Heading from '../../layout/Heading.astro'
import { normalizePath } from '../../utils/normalizePath'
import Icon from '../icons/Icon.astro'
import ServiceVisual from './ServiceVisual.astro'

type Service = NonNullable<ServicesBlock['services']>[number]

type Props = {
  service: Service
  size: 'hero' | 'compact'
  preview: boolean
}

const { service, size, preview } = Astro.props
const isHero = size === 'hero'

const href = normalizePath((service.page as Page)?.path, preview)
---

<a href={href} class="block h-full" aria-label={service.title}>
  <ServiceVisual visualization={service.visualization} size={size} />
  <div class:list={['flex flex-col gap-2 p-6', isHero && 'md:gap-3 md:p-8']}>
    <p class="text-neutral-subtle tracking-eyebrow font-mono text-xs uppercase">
      <span
        class="ease-standard text-tertiary inline-block transition-transform duration-200 group-hover:translate-x-0.5"
        aria-hidden="true"
      >
        \
      </span>
      <span class="ml-1.5">{service.eyebrow}</span>
    </p>
    <Heading as="h3" size="md" class={isHero ? 'md:!text-2xl' : ''}>
      {service.title}
    </Heading>
    <p
      class:list={[
        'text-neutral-muted line-clamp-2 font-sans text-sm leading-[1.55]',
        isHero && 'md:line-clamp-none md:max-w-prose md:text-base',
      ]}
    >
      {service.description}
    </p>
    <Icon
      name="arrow-right"
      class:list={[
        'text-neutral-muted ease-standard group-hover:text-tertiary mt-1 h-4 w-4 self-end transition-colors duration-200',
        isHero && 'md:mt-2 md:h-5 md:w-5',
      ]}
    />
  </div>
</a>
