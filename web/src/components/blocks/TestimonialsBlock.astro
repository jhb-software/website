---
import { payloadSDK } from '@/cms/sdk'
import type { Testimonial, TestimonialsBlock } from 'cms/src/payload-types'
import FrameCell from '../../layout/FrameCell.astro'
import SectionFrame from '../../layout/SectionFrame.astro'
import TestimonialCard from '../cards/TestimonialCard.astro'

export type Props = TestimonialsBlock

const { testimonials } = Astro.props
const { locale, preview, labels } = Astro.locals.globalState

// Fetch the testimonials with depth 3 so the customer logo (testimonial →
// project → customer → logo) resolves to an Image object, not just an id.
const populatedTestimonials = await payloadSDK.find(
  {
    collection: 'testimonials',
    locale: locale,
    draft: false,
    pagination: false,
    depth: 3,
    where: {
      id: {
        in: testimonials.map((testimonial) =>
          typeof testimonial === 'string' ? testimonial : testimonial.id,
        ),
      },
    },
  },
  {
    headers: {
      'X-Use-Cache': preview ? 'false' : 'true',
    },
  },
)

const docs = (populatedTestimonials.docs as Testimonial[] | undefined) ?? []
const useRowLayout = docs.length <= 2
const initialVisibleCount = 6
const showSeeMore = !useRowLayout && docs.length > initialVisibleCount
---

{
  useRowLayout ? (
    <SectionFrame class:list={['grid', docs.length === 1 ? 'grid-cols-1' : 'sm:grid-cols-2']}>
      {docs.map((testimonial, idx) => (
        <FrameCell
          class:list={[
            idx > 0 && 'border-t border-t-[var(--color-hairline-strong)]',
            idx > 0 &&
              docs.length > 1 &&
              'sm:border-t-0 sm:border-l sm:border-l-[var(--color-hairline-strong)]',
          ]}
        >
          <TestimonialCard {...testimonial} />
        </FrameCell>
      ))}
    </SectionFrame>
  ) : (
    <div class="testimonials-grid group relative" id="testimonials-container" data-expanded="false">
      <SectionFrame class="grid sm:grid-cols-2 lg:grid-cols-3">
        {docs.map((testimonial, idx) => (
          <FrameCell
            data-testimonial-index={idx}
            class:list={[
              idx > 0 && 'border-t border-t-[var(--color-hairline-strong)]',
              idx % 2 === 1 && 'sm:border-l sm:border-l-[var(--color-hairline-strong)]',
              idx >= 2 && 'sm:border-t sm:border-t-[var(--color-hairline-strong)]',
              idx % 3 !== 0 && 'lg:border-l lg:border-l-[var(--color-hairline-strong)]',
              idx >= 3 && 'lg:border-t lg:border-t-[var(--color-hairline-strong)]',
            ]}
          >
            <TestimonialCard {...testimonial} />
          </FrameCell>
        ))}
      </SectionFrame>

      {showSeeMore && (
        <div class="see-more-fade pointer-events-none absolute inset-x-0 bottom-0 flex justify-center pt-32 pb-6 group-data-[expanded=true]:hidden">
          <button
            type="button"
            class="bg-cobalt-900 hover:bg-cobalt-800 ease-standard pointer-events-auto inline-flex translate-y-3 cursor-pointer items-center gap-2 rounded-sm px-5 py-3 font-sans text-sm font-medium text-white transition-colors duration-150"
            data-testimonials-toggle
          >
            {labels.global['show-more']}
            <span class="font-mono text-xs opacity-70" aria-hidden="true">
              ↓
            </span>
          </button>
        </div>
      )}
    </div>
  )
}

<style>
  .testimonials-grid[data-expanded='false'] :global(.frame-cell[data-testimonial-index]) {
    /* leave inline; mask handled by gradient overlay below */
  }

  .testimonials-grid[data-expanded='false'] :global(> [class*='SectionFrame']),
  .testimonials-grid[data-expanded='false'] :global(> div:first-child) {
    max-height: 33rem;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
  }
</style>

<script>
  function setupTestimonials() {
    const container = document.getElementById('testimonials-container')
    if (!container) return
    const button = container.querySelector<HTMLButtonElement>('[data-testimonials-toggle]')
    if (!button) return

    const toggle = () => {
      const isExpanded = container.dataset.expanded === 'true'
      container.dataset.expanded = (!isExpanded).toString()
    }

    button.addEventListener('click', toggle)
  }

  document.addEventListener('astro:page-load', setupTestimonials)
</script>
