---
import { payloadSDK } from '@/cms/sdk'
import type { Testimonial, TestimonialsBlock } from 'cms/src/payload-types'
import Eyebrow from '../../layout/Eyebrow.astro'
import TestimonialCard from '../cards/TestimonialCard.astro'
import Icon from '../icons/Icon.astro'

export type Props = TestimonialsBlock & {
  /** Optional section heading. When omitted, the block renders without its own header. */
  heading?: string
  /** Optional eyebrow above the heading. Defaults to STIMMEN/VOICES when `heading` is provided. */
  eyebrow?: string
}

const { testimonials, heading, eyebrow } = Astro.props
const { locale, preview, labels } = Astro.locals.globalState

const sectionEyebrow = eyebrow ?? (locale === 'en' ? 'VOICES' : 'STIMMEN')

// Fetch the testimonials with depth 3 so the customer logo (testimonial →
// project → customer → logo) resolves to an Image object, not just an id.
const populatedTestimonials = await payloadSDK.find(
  {
    collection: 'testimonials',
    locale: locale,
    draft: false,
    pagination: false,
    depth: 3,
    where: {
      id: {
        in: testimonials.map((testimonial) =>
          typeof testimonial === 'string' ? testimonial : testimonial.id,
        ),
      },
    },
  },
  {
    headers: {
      'X-Use-Cache': preview ? 'false' : 'true',
    },
  },
)

const docs = (populatedTestimonials.docs as Testimonial[] | undefined) ?? []

const collapseThreshold = 6
const showSeeMore = docs.length > collapseThreshold

// Pick a column count that doesn't strand a single card in a narrow column.
const listColumns =
  docs.length <= 1 ? 'max-w-2xl' : docs.length === 2 ? 'sm:columns-2' : 'sm:columns-2 lg:columns-3'
---

<div class="testimonials-block group relative" id="testimonials-container" data-expanded="false">
  {
    heading && (
      <header class="mb-8 space-y-3 md:mb-12">
        <Eyebrow label={sectionEyebrow} />
        <h2 class="text-cobalt-900 font-sans text-2xl font-semibold tracking-tight md:text-3xl">
          {heading}
        </h2>
      </header>
    )
  }
  {
    /* The crop lives on this wrapper, not on the column list — so CSS columns
      always balance against the full content height and the cards don't
      reshuffle when expanding. */
  }
  <div class="testimonials-crop">
    <ul class:list={['testimonials-list gap-x-10', listColumns]}>
      {
        docs.map((testimonial) => (
          <li class="mb-2 inline-block w-full break-inside-avoid">
            <TestimonialCard {...testimonial} />
          </li>
        ))
      }
    </ul>
  </div>

  {
    showSeeMore && (
      <div class="see-more-fade pointer-events-none absolute inset-x-0 bottom-0 flex justify-center pt-32 pb-6 group-data-[expanded=true]:hidden">
        <button
          type="button"
          class="bg-cobalt-900 hover:bg-cobalt-800 ease-standard pointer-events-auto inline-flex translate-y-3 cursor-pointer items-center gap-2 rounded-none px-5 py-3 font-sans text-sm font-medium text-white transition-colors duration-150"
          data-testimonials-toggle
        >
          {labels.global['show-more']}
          <Icon name="chevron-down" class="h-4 w-4 opacity-70" />
        </button>
      </div>
    )
  }
</div>

<style>
  .testimonials-block[data-expanded='false']:has(button[data-testimonials-toggle])
    .testimonials-crop {
    max-height: 33rem;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
  }
</style>

<script>
  function setupTestimonials() {
    const container = document.getElementById('testimonials-container')
    if (!container) return
    const button = container.querySelector<HTMLButtonElement>('[data-testimonials-toggle]')
    if (!button) return

    const toggle = () => {
      const isExpanded = container.dataset.expanded === 'true'
      container.dataset.expanded = (!isExpanded).toString()
    }

    button.addEventListener('click', toggle)
  }

  document.addEventListener('astro:page-load', setupTestimonials)
</script>
