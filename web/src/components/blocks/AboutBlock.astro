---
import Img from '@/components/Img.astro'
import Eyebrow from '@/layout/Eyebrow.astro'
import Heading from '@/layout/Heading.astro'
import type { AboutBlock } from 'cms/src/payload-types'
import RichTextBlock from './RichTextBlock/RichTextBlock.astro'

export type Props = AboutBlock

const { title, name, text, image } = Astro.props
---

<div class="grid grid-cols-1 gap-10 md:grid-cols-[280px_1fr] md:gap-12">
  {
    typeof image === 'object' && (
      <div class="border-border-strong aspect-square overflow-hidden border">
        <Img image={image} size="md" class="block h-full w-full object-cover" />
      </div>
    )
  }

  <div class="space-y-6">
    <header class="space-y-3">
      {title && <Eyebrow label={title} />}
      {name && <Heading as="h3">{name}</Heading>}
    </header>

    <div class="prose-redesign text-neutral-muted max-w-prose">
      <RichTextBlock text={text} />
    </div>
  </div>
</div>
