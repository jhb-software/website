---
import type { ContactBlock } from 'cms/src/payload-types'
import FrameCell from '../../layout/FrameCell.astro'
import SectionFrame from '../../layout/SectionFrame.astro'
import Icon from '../icons/Icon.astro'
import Img from '../Img.astro'

type Props = ContactBlock

const { name, image, phone, email, socialLinks } = Astro.props
const { labels } = Astro.locals.globalState

// TODO(cms-content): expose `phoneLabel`, `emailLabel`, `socialLabel` on
// ContactBlock so editors can localise/override. Hardcoded here because the
// existing Labels global has no contact channel keys. Affects: ContactBlock
// CMS schema and any contact-block usage.
const TEL_LABEL = 'TEL'
const MAIL_LABEL = 'E-MAIL'
const SOCIAL_LABEL = 'SOCIAL'
---

<SectionFrame>
  <div class="grid grid-cols-1 md:grid-cols-[minmax(0,360px)_1fr]">
    <FrameCell
      class="border-b border-b-[var(--color-hairline-strong)] md:border-r md:border-b-0 md:border-r-[var(--color-hairline-strong)]"
    >
      {
        typeof image === 'object' && (
          <div class="aspect-square overflow-hidden">
            <Img image={image} size="md" class="block h-full w-full object-cover" />
          </div>
        )
      }
    </FrameCell>

    <FrameCell class="flex flex-col gap-8 p-8 md:p-10">
      <h3 class="text-cobalt-900 font-sans text-2xl font-semibold tracking-tight">{name}</h3>

      <dl class="flex flex-col gap-5">
        <div class="flex flex-col gap-1">
          <dt class="text-ink-500 tracking-eyebrow font-mono text-xs uppercase">
            <span class="text-orange-600" aria-hidden="true">\</span>
            <span class="ml-1.5">{TEL_LABEL}</span>
          </dt>
          <dd>
            <a
              href={`tel:${phone}`}
              class="text-ink-950 ease-standard decoration-hairline-strong font-sans text-base underline underline-offset-4 transition-colors duration-150 hover:text-orange-600 hover:decoration-orange-600"
            >
              {phone}
            </a>
          </dd>
        </div>

        <div class="flex flex-col gap-1">
          <dt class="text-ink-500 tracking-eyebrow font-mono text-xs uppercase">
            <span class="text-orange-600" aria-hidden="true">\</span>
            <span class="ml-1.5">{MAIL_LABEL}</span>
          </dt>
          <dd>
            <a
              href={`mailto:${email}`}
              class="text-ink-950 ease-standard decoration-hairline-strong font-sans text-base break-words underline underline-offset-4 transition-colors duration-150 hover:text-orange-600 hover:decoration-orange-600"
            >
              {email}
            </a>
          </dd>
        </div>

        {
          socialLinks && socialLinks.length > 0 && (
            <div class="flex flex-col gap-2">
              <p class="text-ink-500 tracking-eyebrow font-mono text-xs uppercase">
                <span class="text-orange-600" aria-hidden="true">
                  \
                </span>
                <span class="ml-1.5">{SOCIAL_LABEL}</span>
              </p>
              <div class="flex flex-wrap gap-4">
                {socialLinks.map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-ink-700 ease-standard inline-flex h-9 w-9 items-center justify-center transition-colors duration-150 hover:text-orange-600"
                    aria-label={labels.social[`visit-${link.icon}` as keyof typeof labels.social]}
                  >
                    <Icon name={link.icon} class:list={['h-5 w-5']} />
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </dl>
    </FrameCell>
  </div>
</SectionFrame>
