---
import type { Article, ArticlesBlock } from 'cms/src/payload-types'
import FrameCell from '../../layout/FrameCell.astro'
import SectionFrame from '../../layout/SectionFrame.astro'
import ArticleCard from '../cards/ArticleCard.astro'

export type Props = ArticlesBlock

const articles = (Astro.props.articles as Article[]) ?? []

articles.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())

const [featured, ...rest] = articles
---

<SectionFrame>
  {
    featured && (
      <FrameCell
        interactive
        class:list={[rest.length > 0 && 'border-b border-b-[var(--color-border-strong)]']}
      >
        <ArticleCard {...featured} variant="featured" />
      </FrameCell>
    )
  }

  {
    rest.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2">
        {rest.map((article, idx) => (
          <FrameCell
            interactive
            class:list={[
              idx % 2 === 1 && 'sm:border-l sm:border-l-[var(--color-border-strong)]',
              idx >= 2 && 'border-t border-t-[var(--color-border-strong)]',
              idx === 1 && 'border-t border-t-[var(--color-border-strong)] sm:border-t-0',
            ]}
          >
            <ArticleCard {...article} variant="compact" />
          </FrameCell>
        ))}
      </div>
    )
  }
</SectionFrame>
