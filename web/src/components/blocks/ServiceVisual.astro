---
import type { ServicesBlock } from 'cms/src/payload-types'

type Service = NonNullable<ServicesBlock['services']>[number]

type Props = {
  visualization: Service['visualization']
  size?: 'hero' | 'compact'
}

const { visualization, size = 'compact' } = Astro.props
const heightClass = size === 'hero' ? 'h-36 md:h-72' : 'h-36'
---

<div
  class:list={[
    'service-visual relative overflow-hidden border-b border-b-[var(--color-border-strong)] bg-white',
    heightClass,
  ]}
>
  <div class="visual-grid pointer-events-none absolute inset-0" aria-hidden="true"></div>
  <svg
    class="relative z-10 h-full w-full"
    viewBox="0 0 220 140"
    preserveAspectRatio="xMidYMid meet"
    fill="none"
    aria-hidden="true"
  >
    {
      visualization === 'mobile' && (
        <>
          <rect
            x="85"
            y="14"
            width="50"
            height="112"
            rx="6"
            stroke="var(--color-primary)"
            stroke-width="1.5"
          />
          <line
            x1="103"
            y1="22"
            x2="117"
            y2="22"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
          <rect
            x="92"
            y="36"
            width="36"
            height="10"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
          <rect
            x="92"
            y="50"
            width="36"
            height="10"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
          <rect
            x="92"
            y="64"
            width="36"
            height="10"
            stroke="var(--color-tertiary)"
            stroke-width="1.5"
            fill="var(--color-tertiary-soft)"
          />
          <rect
            x="92"
            y="78"
            width="36"
            height="10"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
          <rect
            x="92"
            y="92"
            width="36"
            height="10"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
          <circle cx="110" cy="116" r="3" fill="var(--color-primary)" />
        </>
      )
    }

    {
      visualization === 'web' && (
        <>
          {/* Editor (top) */}
          <rect
            x="22"
            y="20"
            width="80"
            height="44"
            stroke="var(--color-primary)"
            stroke-width="1.5"
            fill="white"
          />
          <line
            x1="22"
            y1="32"
            x2="102"
            y2="32"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
          <line
            x1="32"
            y1="42"
            x2="68"
            y2="42"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
          <line
            x1="32"
            y1="50"
            x2="92"
            y2="50"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
          <line
            x1="32"
            y1="58"
            x2="76"
            y2="58"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />

          {/* Connecting arrow */}
          <path
            d="M 110 70 L 110 80 M 105 75 L 110 80 L 115 75"
            stroke="var(--color-tertiary)"
            stroke-width="1.5"
            stroke-linecap="round"
          />

          {/* Rendered site (bottom) */}
          <rect
            x="118"
            y="76"
            width="80"
            height="44"
            stroke="var(--color-primary)"
            stroke-width="1.5"
            fill="white"
          />
          <rect x="124" y="82" width="20" height="12" fill="var(--color-primary)" />
          <line
            x1="124"
            y1="100"
            x2="192"
            y2="100"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
          <line
            x1="124"
            y1="108"
            x2="172"
            y2="108"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
          <line
            x1="124"
            y1="116"
            x2="160"
            y2="116"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
        </>
      )
    }

    {
      visualization === 'webapp' && (
        <>
          {/* Bars */}
          <rect x="14" y="84" width="14" height="36" fill="var(--color-primary)" />
          <rect x="32" y="68" width="14" height="52" fill="var(--color-primary)" />
          <rect x="50" y="50" width="14" height="70" fill="var(--color-tertiary)" />
          <rect x="68" y="74" width="14" height="46" fill="var(--color-primary)" />
          <rect x="86" y="58" width="14" height="62" fill="var(--color-primary)" />
          <rect x="104" y="78" width="14" height="42" fill="var(--color-primary)" />
          <rect x="122" y="64" width="14" height="56" fill="var(--color-primary)" />

          {/* Stat cards */}
          <rect
            x="148"
            y="20"
            width="56"
            height="22"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
          <text
            x="156"
            y="36"
            font-family="Geist Mono, ui-monospace, monospace"
            font-size="10"
            font-weight="600"
            fill="var(--color-primary)"
          >
            2.4k
          </text>
          <rect
            x="148"
            y="48"
            width="56"
            height="22"
            stroke="var(--color-border-strong)"
            stroke-width="1"
          />
          <text
            x="156"
            y="64"
            font-family="Geist Mono, ui-monospace, monospace"
            font-size="10"
            font-weight="600"
            fill="var(--color-primary)"
          >
            98.2%
          </text>

          {/* Sparkline */}
          <polyline
            points="148,100 156,96 164,103 172,90 180,86 188,93 196,88 204,96"
            stroke="var(--color-tertiary)"
            stroke-width="1.5"
            fill="none"
            stroke-linejoin="round"
          />
        </>
      )
    }
  </svg>
</div>

<style>
  .visual-grid {
    background-image:
      linear-gradient(to right, var(--color-border-strong) 1px, transparent 1px),
      linear-gradient(to bottom, var(--color-border-strong) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.4;
  }
</style>
