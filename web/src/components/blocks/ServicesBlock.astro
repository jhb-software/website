---
import type { ServicesBlock } from 'cms/src/payload-types'
import FrameCell from '../../layout/FrameCell.astro'
import SectionFrame from '../../layout/SectionFrame.astro'
import ServiceCard from './ServiceCard.astro'

export type Props = ServicesBlock

const { services } = Astro.props
const { preview } = Astro.locals.globalState

// The bento layout (one large hero cell + two compact cells) is used when a
// services array contains exactly one item flagged `isHero` and at least two
// non-hero items. Anything else falls back to a 3-up grid of compact cells.
const heroService = services?.find((s) => s.isHero)
const compactServices = (services ?? []).filter((s) => !s.isHero)
const useBento = heroService && compactServices.length >= 2
---

{
  useBento ? (
    <SectionFrame class="grid md:grid-cols-[1.4fr_1fr] md:grid-rows-2">
      <FrameCell
        interactive
        class="md:row-span-2 md:border-r md:border-r-[var(--color-border-strong)]"
      >
        <ServiceCard service={heroService} size="hero" preview={preview} />
      </FrameCell>

      {compactServices.slice(0, 2).map((service, idx) => (
        <FrameCell
          interactive
          class:list={[idx === 1 && 'md:border-t md:border-t-[var(--color-border-strong)]']}
        >
          <ServiceCard service={service} size="compact" preview={preview} />
        </FrameCell>
      ))}
    </SectionFrame>
  ) : (
    <SectionFrame class="grid md:grid-cols-3">
      {services?.map((service, idx) => (
        <FrameCell
          interactive
          class:list={[idx > 0 && 'md:border-l md:border-l-[var(--color-border-strong)]']}
        >
          <ServiceCard service={service} size="compact" preview={preview} />
        </FrameCell>
      ))}
    </SectionFrame>
  )
}
