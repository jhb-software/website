---
import ArrowRight from './arrow-right.svg'
import BarsStaggered from './bars-staggered.svg'
import Building from './building.svg'
import ChevronDown from './chevron-down.svg'
import ChevronLeft from './chevron-left.svg'
import ChevronRight from './chevron-right.svg'
import Comments from './comments.svg'
import Facebook from './facebook.svg'
import Github from './github.svg'
import Home from './home.svg'
import Instagram from './instagram.svg'
import LaptopCode from './laptop-code.svg'
import Laptop from './laptop.svg'
import Linkedin from './linkedin.svg'
import MobilePhone from './mobile-phone.svg'
import RefreshCw from './refresh-cw.svg'
import WhatsApp from './whatsapp.svg'
import X from './x.svg'
import Youtube from './youtube.svg'

type Props = {
  name:
    | 'arrow-right'
    | 'bars-staggered'
    | 'comments'
    | 'mobile-phone'
    | 'laptop'
    | 'laptop-code'
    | 'github'
    | 'linkedin'
    | 'whatsapp'
    | 'instagram'
    | 'facebook'
    | 'youtube'
    | 'x'
    | 'chevron-right'
    | 'chevron-down'
    | 'chevron-left'
    | 'building'
    | 'home'
    | 'refresh-cw'
  class?: string
}

// Geist icons render with stroke + viewBox only (no intrinsic width/height) so a
// sizing class is required to avoid a 0-px-tall SVG. Default to h-4 w-4 when the
// caller doesn't pass one.
const { name, class: classNames = 'h-4 w-4' } = Astro.props
---

{
  () => {
    switch (name) {
      case 'arrow-right':
        return <ArrowRight class:list={classNames} />
      case 'bars-staggered':
        return <BarsStaggered class:list={classNames} />
      case 'comments':
        return <Comments class:list={classNames} />
      case 'mobile-phone':
        return <MobilePhone class:list={classNames} />
      case 'laptop':
        return <Laptop class:list={classNames} />
      case 'laptop-code':
        return <LaptopCode class:list={classNames} />
      case 'github':
        return <Github class:list={classNames} />
      case 'linkedin':
        return <Linkedin class:list={classNames} />
      case 'whatsapp':
        return <WhatsApp class:list={classNames} />
      case 'instagram':
        return <Instagram class:list={classNames} />
      case 'facebook':
        return <Facebook class:list={classNames} />
      case 'youtube':
        return <Youtube class:list={classNames} />
      case 'x':
        return <X class:list={classNames} />
      case 'chevron-right':
        return <ChevronRight class:list={classNames} />
      case 'chevron-down':
        return <ChevronDown class:list={classNames} />
      case 'chevron-left':
        return <ChevronLeft class:list={classNames} />
      case 'building':
        return <Building class:list={classNames} />
      case 'home':
        return <Home class:list={classNames} />
      case 'refresh-cw':
        return <RefreshCw class:list={classNames} />
      default:
        throw new Error(`Icon ${name} not found`)
    }
  }
}
