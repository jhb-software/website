---
import type { Project } from 'cms/src/payload-types'
import TagsList from './TagsList.astro'

type Props = {
  tags: Project['tags']
  class?: string
}

const { tags, class: className } = Astro.props
const { labels } = Astro.locals.globalState

const resolved = (tags ?? []).map((tag) => labels.projects[tag])
---

<TagsList labels={resolved} class={className} />
