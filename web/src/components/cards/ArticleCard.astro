---
import { payloadSDK } from '@/cms/sdk'
import Eyebrow from '@/layout/Eyebrow.astro'
import type { Article, Author } from 'cms/src/payload-types'
import { normalizePath } from '../../utils/normalizePath'
import ArticleTagsList from '../ArticleTagsList.astro'
import Icon from '../icons/Icon.astro'
import Img from '../Img.astro'

type Props = Article & {
  variant?: 'featured' | 'compact'
}

const { variant = 'compact', ...article } = Astro.props
const { locale, preview } = Astro.locals.globalState

const href = normalizePath(article.path, preview)
const dateLabel = new Date(article.createdAt).toLocaleDateString(locale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

let authors: Author[] = []
if (variant === 'featured' && article.authors?.length) {
  // TODO: populate the authors image when fetching the articles block to avoid this SDK request.
  const result = await payloadSDK.find(
    {
      collection: 'authors',
      locale: locale,
      draft: preview,
      where: {
        id: {
          in: article.authors.map((author) => (author as Author).id),
        },
        _status: preview ? { in: ['draft', 'published'] } : { equals: 'published' },
      },
      limit: 3,
      pagination: false,
    },
    {
      headers: {
        'X-Use-Cache': preview ? 'false' : 'true',
      },
    },
  )

  authors = result.docs
}
---

{
  variant === 'featured' ? (
    <a
      href={href}
      class="grid h-full grid-cols-1 md:grid-cols-[1.2fr_1fr]"
      aria-label={article.title}
    >
      <div class="border-border-strong relative overflow-hidden border-b md:border-r md:border-b-0">
        {typeof article.image === 'object' && (
          <Img
            image={article.image}
            size="lg"
            fetchpriority="high"
            class="block aspect-[16/10] h-full w-full object-cover"
          />
        )}
      </div>

      <div class="flex flex-col gap-4 p-8 md:p-10">
        <Eyebrow label={dateLabel} />

        <h3 class="text-primary font-sans text-2xl font-semibold tracking-tight text-balance">
          {article.title}
        </h3>

        <p class="text-neutral-muted max-w-prose font-sans text-base leading-[1.55]">
          {article.excerpt}
        </p>

        <ArticleTagsList tags={article.tags} class="mt-1" />

        {authors.length > 0 && (
          <div class="border-border mt-auto flex items-center gap-3 border-t pt-4">
            <div class="flex flex-shrink-0 -space-x-2">
              {authors.map(
                (author) =>
                  typeof author.photo === 'object' && (
                    <Img
                      image={author.photo}
                      size="sm"
                      class="border-surface aspect-square !h-8 !w-8 rounded-full border-2 object-cover"
                    />
                  ),
              )}
            </div>
            <p class="text-neutral-muted font-sans text-sm">
              {authors.map((author, index) => [
                index > 0 ? ', ' : '',
                <span class="font-medium">{author.name}</span>,
              ])}
            </p>
            <Icon
              name="arrow-right"
              class="text-neutral-muted ease-standard group-hover:text-tertiary ml-auto h-5 w-5 transition-colors duration-200"
            />
          </div>
        )}
      </div>
    </a>
  ) : (
    <a href={href} class="flex h-full flex-col" aria-label={article.title}>
      <div class="border-border-strong overflow-hidden border-b">
        {typeof article.image === 'object' && (
          <Img
            image={article.image}
            size="md"
            loading="lazy"
            class="block aspect-[16/10] h-full w-full object-cover"
          />
        )}
      </div>

      <div class="flex flex-1 flex-col gap-3 p-6 md:p-8">
        <Eyebrow label={dateLabel} />

        <h3 class="text-primary font-sans text-lg font-semibold tracking-tight text-balance">
          {article.title}
        </h3>

        <p class="text-neutral-muted line-clamp-3 font-sans text-sm leading-[1.55]">
          {article.excerpt}
        </p>

        <div class="mt-auto flex items-end justify-between gap-3 pt-4">
          <ArticleTagsList tags={article.tags} />
          <Icon
            name="arrow-right"
            class="text-neutral-muted ease-standard group-hover:text-tertiary h-5 w-5 transition-colors duration-200"
          />
        </div>
      </div>
    </a>
  )
}
