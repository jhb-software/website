---
import type { Project } from 'cms/src/payload-types'
import { normalizePath } from '../../utils/normalizePath'
import Img from '../Img.astro'
import ProjectDate from '../ProjectDate.astro'
import ProjectTagsList from '../ProjectTagsList.astro'

type Props = Project & {
  /** Featured: image left + meta right, large image. Compact: single row, small image + title + tags. */
  variant?: 'featured' | 'compact'
  fetchpriority?: 'high' | 'low' | 'auto'
}

const { variant = 'compact', fetchpriority, ...project } = Astro.props
const { preview } = Astro.locals.globalState

const href = normalizePath(project.path, preview)
---

{
  variant === 'featured' ? (
    <a
      href={href}
      class="grid h-full grid-cols-1 md:grid-cols-[1.2fr_1fr]"
      aria-label={project.title}
    >
      <div class="border-hairline-strong relative overflow-hidden border-b md:border-r md:border-b-0">
        {typeof project.image === 'object' && (
          <Img
            image={project.image}
            size="lg"
            fetchpriority={fetchpriority}
            class="block aspect-[16/10] h-full w-full object-cover"
          />
        )}
      </div>

      <div class="flex flex-col gap-4 p-8 md:p-10">
        <ProjectDate startDate={project.startDate} endDate={project.endDate} />

        <h3 class="text-cobalt-900 font-sans text-2xl font-semibold tracking-tight text-balance">
          {project.title}
        </h3>

        <p class="text-ink-700 max-w-prose font-sans text-base leading-[1.55]">{project.excerpt}</p>

        <ProjectTagsList tags={project.tags} class="mt-2" />

        <span
          class="text-ink-700 ease-standard mt-auto self-end pt-4 font-mono text-base transition-colors duration-200 group-hover:text-orange-600"
          aria-hidden="true"
        >
          &rarr;
        </span>
      </div>
    </a>
  ) : (
    <a
      href={href}
      class="flex h-full items-center gap-5 p-5 md:gap-8 md:p-6"
      aria-label={project.title}
    >
      <div class="border-hairline-strong w-32 flex-none overflow-hidden border md:w-44">
        {typeof project.image === 'object' && (
          <Img
            image={project.image}
            size="sm"
            class="block aspect-[16/10] h-full w-full object-cover"
          />
        )}
      </div>

      <div class="flex min-w-0 flex-1 flex-col gap-2">
        <h3 class="text-cobalt-900 font-sans text-base font-semibold tracking-tight md:text-lg">
          {project.title}
        </h3>
        <ProjectTagsList tags={project.tags} />
        <ProjectDate startDate={project.startDate} endDate={project.endDate} class="mt-1" />
      </div>

      <span
        class="text-ink-700 ease-standard hidden flex-none font-mono text-base transition-colors duration-200 group-hover:text-orange-600 md:inline"
        aria-hidden="true"
      >
        &rarr;
      </span>
    </a>
  )
}
