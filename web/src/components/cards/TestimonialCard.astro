---
import type { Testimonial } from 'cms/src/payload-types'
import Img from '../Img.astro'

export type Props = Testimonial

const { project, author, text } = Astro.props

const customer =
  typeof project === 'object' && 'customer' in project && typeof project.customer === 'object'
    ? project.customer
    : undefined

if (!customer) {
  throw new Error(`Customer not populated, got: ${JSON.stringify(Astro.props)}`)
}
---

<figure class="border-hairline-strong flex flex-col gap-5 rounded-sm border bg-white p-6">
  <header class="flex items-center gap-4">
    {
      typeof author.image === 'object' && (
        <Img
          image={author.image}
          size="sm"
          class="aspect-square h-10 w-10 shrink-0 rounded-full object-cover"
        />
      )
    }

    <div class="min-w-0 flex-1">
      <div class="text-cobalt-900 truncate font-sans text-sm font-medium">
        {author.name}
      </div>
      {
        customer.websiteUrl ? (
          <a
            href={customer.websiteUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-ink-500 ease-standard tracking-eyebrow inline-block truncate font-mono text-xs uppercase transition-colors duration-150 hover:text-orange-600"
          >
            {customer.name}
          </a>
        ) : (
          <span class="text-ink-500 tracking-eyebrow inline-block truncate font-mono text-xs uppercase">
            {customer.name}
          </span>
        )
      }
    </div>
  </header>

  <blockquote class="text-ink-950 max-w-prose font-sans text-base leading-[1.55]">
    {text}
  </blockquote>
</figure>
