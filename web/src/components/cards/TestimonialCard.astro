---
import type { Testimonial } from 'cms/src/payload-types'
import Img from '../Img.astro'

export type Props = Testimonial

const { project, author, text } = Astro.props

const customer =
  typeof project === 'object' && 'customer' in project && typeof project.customer === 'object'
    ? project.customer
    : undefined

if (!customer) {
  throw new Error(`Customer not populated, got: ${JSON.stringify(Astro.props)}`)
}

const customerLogo = typeof customer.logo === 'object' ? customer.logo : undefined
---

<figure class="flex h-full flex-col gap-6 p-6">
  <blockquote class="text-ink-950 max-w-prose flex-1 font-sans text-base leading-[1.55]">
    {text}
  </blockquote>

  <figcaption class="border-hairline mt-auto flex items-center gap-4 border-t pt-5">
    {
      typeof author.image === 'object' && (
        <Img
          image={author.image}
          size="sm"
          class="aspect-square h-10 w-10 shrink-0 rounded-full object-cover"
        />
      )
    }

    <div class="min-w-0 flex-1">
      <div class="text-cobalt-900 truncate font-sans text-sm font-medium">
        {author.name}
      </div>

      {
        (() => {
          const companyContent = (
            <span class="inline-flex items-center gap-2 truncate">
              {customerLogo && (
                <Img
                  image={customerLogo}
                  size="original"
                  width={48}
                  class="h-4 w-auto max-w-[48px] shrink-0 opacity-60 grayscale [filter:brightness(0)]"
                />
              )}
              <span class="tracking-eyebrow truncate font-mono text-xs uppercase">
                {customer.name}
              </span>
            </span>
          )

          return customer.websiteUrl ? (
            <a
              href={customer.websiteUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-ink-500 ease-standard inline-flex items-center transition-colors duration-150 hover:text-orange-600"
            >
              {companyContent}
            </a>
          ) : (
            <span class="text-ink-500 inline-flex items-center">{companyContent}</span>
          )
        })()
      }
    </div>
  </figcaption>
</figure>
