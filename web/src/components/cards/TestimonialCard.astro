---
import type { Testimonial } from 'cms/src/payload-types'
import Img from '../Img.astro'

export type Props = Testimonial

const { project, author, text } = Astro.props

const customer =
  typeof project === 'object' && 'customer' in project && typeof project.customer === 'object'
    ? project.customer
    : undefined

if (!customer) {
  throw new Error(`Customer not populated, got: ${JSON.stringify(Astro.props)}`)
}
---

<figure class="flex h-full flex-col gap-6 p-6">
  <blockquote class="text-ink-950 max-w-prose flex-1 font-sans text-base leading-[1.55]">
    {text}
  </blockquote>

  <figcaption class="border-hairline mt-auto flex items-center gap-4 border-t pt-5">
    {
      typeof author.image === 'object' && (
        <Img
          image={author.image}
          size="sm"
          class="aspect-square h-10 w-10 shrink-0 rounded-full object-cover"
        />
      )
    }

    <div class="min-w-0">
      <div class="text-cobalt-900 truncate font-sans text-sm font-medium">
        {author.name}
      </div>
      {
        customer.websiteUrl ? (
          <a
            href={customer.websiteUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-ink-500 ease-standard tracking-eyebrow truncate font-mono text-xs uppercase transition-colors duration-150 hover:text-orange-600"
          >
            {customer.name}
          </a>
        ) : (
          <span class="text-ink-500 tracking-eyebrow truncate font-mono text-xs uppercase">
            {customer.name}
          </span>
        )
      }
    </div>
  </figcaption>
</figure>
