{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)\\.md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://cms.jhb.software"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=(), payment=()"
        }
      ]
    },
    {
      "source": "/media/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, s-maxage=31536000, stale-while-revalidate=86400, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/media/:path*",
      "destination": "https://jhb-software.nbg1.your-objectstorage.com/:path*"
    },
    {
      "source": "/js/script.js",
      "destination": "https://plausible.io/js/plausible.js"
    },
    {
      "source": "/api/event",
      "destination": "https://plausible.io/api/event"
    }
  ],
  "redirects": [
    {
      "source": "/payload-pages-plugin",
      "destination": "https://www.npmjs.com/package/@jhb.software/payload-pages-plugin",
      "statusCode": 302
    },
    {
      "source": "/payload-content-translator-plugin",
      "destination": "https://www.npmjs.com/package/@jhb.software/payload-content-translator-plugin",
      "statusCode": 302
    },
    {
      "source": "/astro-payload-richtext-lexical",
      "destination": "https://www.npmjs.com/package/@jhb.software/astro-payload-richtext-lexical",
      "statusCode": 302
    },
    {
      "source": "/payload-cloudinary-plugin",
      "destination": "https://www.npmjs.com/package/@jhb.software/payload-cloudinary-plugin",
      "statusCode": 302
    },
    {
      "source": "/payload-admin-search",
      "destination": "https://www.npmjs.com/package/@jhb.software/payload-admin-search",
      "statusCode": 302
    },
    {
      "source": "/payload-alt-text-plugin",
      "destination": "https://www.npmjs.com/package/@jhb.software/payload-alt-text-plugin",
      "statusCode": 302
    },
    {
      "source": "/payload-geocoding-plugin",
      "destination": "https://www.npmjs.com/package/@jhb.software/payload-geocoding-plugin",
      "statusCode": 302
    },
    {
      "source": "/payload-vercel-deployments",
      "destination": "https://www.npmjs.com/package/@jhb.software/payload-vercel-deployments",
      "statusCode": 302
    }
  ],
  "trailingSlash": false
}
